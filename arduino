void setup() {
  Serial.begin(115200);

  // Initialize buzzer FIRST to prevent floating
  pinMode(BUZZER_PIN, OUTPUT);
  noTone(BUZZER_PIN);

  pinMode(PIR_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  noTone(BUZZER_PIN);

  lcd.init();
  lcd.backlight();
  lcdShow("WATCHTOWER", "Initializing...", "", "");

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 30) {
    delay(500);
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    timeClient.begin();
    timeClient.update();
    lcdShow("WATCHTOWER", "WiFi Connected!", WiFi.localIP().toString(), "");
  } else {
    lcdShow("WATCHTOWER", "WiFi FAILED", "Running offline", "");
  }

  delay(2000);
  updateConnectionStatus();
  lcdShow("WATCHTOWER", "Waiting for app", "Please connect", "");
}

void loop() {
